>> A=[1 2; 3 4]

A =

     1     2
     3     4

>> B=[5 6; 7 8]

B =

     5     6
     7     8

>> C=[9 10; 11 12]

C =

     9    10
    11    12
-------------------------------------------------------------------------------------------

>> mat2str(isequal(A+B,B+A))

ans =

    'true'
-------------------------------------------------------------------------------------------

>> mat2str(isequal(A-B,B-A))

ans =

    'false'
-------------------------------------------------------------------------------------------

>> mat2str(isequal(A+(B+C),(A+B)+C))

ans =

    'true'
--------------------------------------------------------------------------------------------
>> mat2str(isequal(A*(B+C),A*B+A*C))

ans =

    'true'
--------------------------------------------------------------------------------------------

>> mat2str(isequal((B+C)/A,B/A+C/A))

ans =

    'false'
--------------------------------------------------------------------------------------------

>> mat2str(isequal(A*B,B*A))

ans =

    'false'
--------------------------------------------------------------------------------------------

>> mat2str(isequal(A*1,A))

ans =

    'true'
---------------------------------------------------------------------------------------------

>> mat2str(isequal(A*A^-1,1))

ans =

    'false'
----------------------------------------------------------------------------------------------

>> mat2str(isequal(A,A'))

ans =

    'false'
----------------------------------------------------------------------------------------------

>> mat2str(isequal(A,-A'))

ans =

    'false'
